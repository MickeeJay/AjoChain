# ============================================================
# AjoChain — Hardhat environment variables
# ============================================================
# Copy this file to .env in this same folder (contracts/) and
# fill in your real values. The .env file is gitignored.
#
#   cp .env.example .env
#
# DO NOT commit the .env file. Never share your private key.
# ============================================================

# ----------------------------------------------------------
# Deployer wallet
# ----------------------------------------------------------
# The private key of the wallet that will sign deployment
# transactions on Alfajores or Celo mainnet.
#
# Format:  0x followed by 64 hex characters (32 bytes).
# Example: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
#
# Get a key: cast wallet new  (Foundry)
#             or any wallet's "export private key" option.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# ----------------------------------------------------------
# Celoscan verification
# ----------------------------------------------------------
# Required by:  scripts/verify.ts
#               npm run verify / verify:testnet
#
# Get one free at https://celoscan.io/myapikey
CELOSCAN_API_KEY=YOUR_CELOSCAN_API_KEY

# ----------------------------------------------------------
# Gas reporting (optional)
# ----------------------------------------------------------
# Set to "true" to enable per-function gas usage in test output.
# Leave blank or omit to keep reports off.
REPORT_GAS=
