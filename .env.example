# ============================================================
# AjoChain — Frontend environment variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# The .env.local file is gitignored. Never commit real secrets.
#
#   cp .env.example .env.local
# ============================================================

# Public Celo mainnet RPC endpoint.
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Public Alfajores testnet RPC endpoint.
NEXT_PUBLIC_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Deployed AjoGroupFactory contract address on Celo mainnet.
NEXT_PUBLIC_FACTORY_CONTRACT_ADDRESS=0xAb672F162220ebB17B82bBcf8823Cd0f141515b9

# Deployed AjoCredential contract address on Celo mainnet.
NEXT_PUBLIC_CREDENTIAL_CONTRACT_ADDRESS=0x70A8C3AbF529B26dB520a12ea63276cceb50bB30

# WalletConnect project ID for wallet sessions.
# Register at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Chain IDs.
NEXT_PUBLIC_CELO_CHAIN_ID=42220
NEXT_PUBLIC_ALFAJORES_CHAIN_ID=44787

# Public app URL used for invite links and Open Graph metadata.
NEXT_PUBLIC_APP_URL=https://ajochain.vercel.app

# cUSD contract addresses (public, not secrets).
NEXT_PUBLIC_CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_CUSD_ALFAJORES=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# ============================================================
# NextAuth (Auth.js) — Social login
# ============================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-random-string

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twitter (X) OAuth 2.0 — https://developer.x.com/en/portal/dashboard
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
