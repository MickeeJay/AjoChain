# Public Celo mainnet RPC endpoint used by the frontend for read-only chain access.
NEXT_PUBLIC_CELO_RPC_URL=https://your-celo-mainnet-rpc.example/v1/YOUR_API_KEY

# Public Alfajores testnet RPC endpoint used for development and test deployments.
NEXT_PUBLIC_ALFAJORES_RPC_URL=https://your-alfajores-rpc.example/v1/YOUR_API_KEY

# Deployed GroupFactory contract address on Celo mainnet.
NEXT_PUBLIC_FACTORY_CONTRACT_ADDRESS=0xYOUR_FACTORY_CONTRACT_ADDRESS

# Deployer wallet private key for Hardhat scripts only. Never expose this to the frontend or commit a real key.
PRIVATE_KEY=0xYOUR_HARDHAT_DEPLOYER_PRIVATE_KEY

# WalletConnect project ID used by viem and wagmi for wallet sessions.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Celo mainnet chain ID used by the app.
NEXT_PUBLIC_CELO_CHAIN_ID=42220

# Alfajores testnet chain ID used by the app.
NEXT_PUBLIC_ALFAJORES_CHAIN_ID=44787

# cUSD contract address on Celo mainnet.
NEXT_PUBLIC_CUSD_ADDRESS=0xYOUR_CELO_MAINNET_CUSD_ADDRESS

# cUSD contract address on Alfajores testnet.
NEXT_PUBLIC_CUSD_ALFAJORES=0xYOUR_ALFAJORES_CUSD_ADDRESS
